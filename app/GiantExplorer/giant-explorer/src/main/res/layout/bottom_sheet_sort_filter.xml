<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sort_and_filter"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <!-- 排序方式 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sort_by"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <RadioGroup
        android:id="@+id/sort_type_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/sort_by_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_by_name"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_by_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_by_size"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_by_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_by_time"
            android:padding="8dp" />
    </RadioGroup>

    <!-- 排序方向 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sort_direction"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <RadioGroup
        android:id="@+id/sort_direction_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/sort_ascending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_ascending"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/sort_descending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_descending"
            android:padding="8dp" />
    </RadioGroup>

    <!-- 过滤选项 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/filter_options"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <CheckBox
        android:id="@+id/filter_hidden_files"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/filter_hidden_file"
        android:padding="8dp" />

</LinearLayout>
